# Q5+Q6 / PRIME / Community + Market — 환경변수 예시
# 실제 값은 .env.local 에 작성 (gitignored)

# 1) DATABASE_URL (필수) — Supabase pooler. Q3·Q4와 동일 DB 공유.
# 4주차 .env.local 또는 Q3 .env.local 에서 복사 가능.
DATABASE_URL=postgresql://postgres.<ref>:<URL_ENCODED_PASSWORD>@aws-1-<region>.pooler.supabase.com:6543/postgres

# 2) JWT_SECRET (필수) — 토큰 서명 키.
# 미설정 시 권장: PowerShell로 자동 생성 후 추가
#   $b = New-Object byte[] 64
#   [System.Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($b)
#   "JWT_SECRET=" + (-join ($b | %{ "{0:x2}" -f $_ })) | Add-Content .env.local
JWT_SECRET=<128 hex chars (512-bit)>

# 3) ANTHROPIC_API_KEY (옵셔널) — Q4 분석 기능을 Q5/Q6에 통합할 때만 필요.
# Phase 1·2·3 기본 동작에는 불필요. 확장 시 4주차 .env.local 에서 복사.
# ANTHROPIC_API_KEY=sk-ant-<...>

# 4) PORT (옵셔널, 기본 3002) — dev-server.js 로컬 포트 (Q3 3000과 충돌 방지)
# PORT=3002
