{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/api/auth", "destination": "/api/auth" },
    { "source": "/api/posts", "destination": "/api/posts" },
    { "source": "/api/shop", "destination": "/api/shop" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/auth.js": { "maxDuration": 10 },
    "api/posts.js": { "maxDuration": 10 },
    "api/shop.js": { "maxDuration": 10 }
  }
}
